generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  FINANCEIRO
  RH
  PERFURACAO
  LEITOR
}

enum EntryType {
  ENTRADA
  SAIDA
}

enum DailyRole {
  AJUDANTE
  OPERADOR
}

enum EmployeeType {
  DIARISTA
  FICHADO
}

enum PaymentStatus {
  PENDENTE
  PAGO
}

enum AdvanceStatus {
  PENDENTE
  DESCONTADO
}

enum AdditionStatus {
  PENDENTE
  INCLUIDO
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  passwordHash       String   @map("password_hash")
  role               UserRole @default(LEITOR)
  isActive           Boolean  @default(true) @map("is_active")
  canAccessFinance   Boolean  @default(true) @map("can_access_finance")
  canWriteFinance    Boolean  @default(false) @map("can_write_finance")
  canAccessDaily     Boolean  @default(true) @map("can_access_daily")
  canWriteDaily      Boolean  @default(false) @map("can_write_daily")
  canAccessDrilling  Boolean  @default(true) @map("can_access_drilling")
  canWriteDrilling   Boolean  @default(false) @map("can_write_drilling")
  canManageUsers     Boolean  @default(false) @map("can_manage_users")
  lastLoginAt        DateTime? @map("last_login_at")
  lastActivityAt     DateTime? @map("last_activity_at")
  lastActivityPath   String?   @map("last_activity_path")
  activityCount      Int       @default(0) @map("activity_count")
  lastReportViewAt   DateTime? @map("last_report_view_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model FinancialSheet {
  id          String   @id @default(cuid())
  name        String
  description String?
  purpose     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entries FinancialEntry[]

  @@map("financial_sheets")
}

model FinancialEntry {
  id        String    @id @default(cuid())
  sheetId   String    @map("sheet_id")
  date      DateTime
  type      EntryType
  item      String
  quantity  String?
  value     Decimal   @db.Decimal(14, 2)
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  sheet FinancialSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@index([sheetId, date])
  @@map("financial_entries")
}

model PayrollEmployee {
  id                  String       @id @default(cuid())
  name                String       @unique
  role                DailyRole
  type                EmployeeType @default(DIARISTA)
  dailyValue          Decimal?     @map("daily_value") @db.Decimal(14, 2)
  monthlySalary       Decimal?     @map("monthly_salary") @db.Decimal(14, 2)
  defaultOvertimeRate Decimal?     @map("default_overtime_rate") @db.Decimal(14, 2)
  isActive            Boolean      @default(true) @map("is_active")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  entries DailyEntry[]

  @@index([name, isActive])
  @@map("payroll_employees")
}

model DailyEntry {
  id              String        @id @default(cuid())
  date            DateTime
  employeeName    String        @map("employee_name")
  employeeId      String?       @map("employee_id")
  role            DailyRole
  employeeType    EmployeeType  @default(DIARISTA) @map("employee_type")
  monthlySalary   Decimal?      @map("monthly_salary") @db.Decimal(14, 2)
  dailyValue      Decimal       @map("daily_value") @db.Decimal(14, 2)
  overtimeHours   Decimal       @default(0) @map("overtime_hours") @db.Decimal(8, 2)
  overtimeRate    Decimal       @default(0) @map("overtime_rate") @db.Decimal(14, 2)
  overtimeTotal   Decimal       @default(0) @map("overtime_total") @db.Decimal(14, 2)
  dayTotal        Decimal       @map("day_total") @db.Decimal(14, 2)
  notes           String?
  status          PaymentStatus @default(PENDENTE)
  closureId       String?       @map("closure_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  closure PayrollClosure? @relation(fields: [closureId], references: [id])
  employee PayrollEmployee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([employeeName, date, status])
  @@index([employeeId])
  @@index([closureId])
  @@map("daily_entries")
}

model PayrollClosure {
  id            String   @id @default(cuid())
  employeeName  String   @map("employee_name")
  role          DailyRole
  employeeType  EmployeeType @default(DIARISTA) @map("employee_type")
  periodStart   DateTime @map("period_start")
  periodEnd     DateTime @map("period_end")
  paidAt        DateTime @default(now()) @map("paid_at")
  daysWorked    Int      @map("days_worked")
  totalDaily    Decimal  @map("total_daily") @db.Decimal(14, 2)
  totalOvertime Decimal  @map("total_overtime") @db.Decimal(14, 2)
  totalAdvance  Decimal  @default(0) @map("total_advance") @db.Decimal(14, 2)
  totalAddition Decimal  @default(0) @map("total_addition") @db.Decimal(14, 2)
  totalPaid     Decimal  @map("total_paid") @db.Decimal(14, 2)
  receiptNumber String   @unique @map("receipt_number")
  createdAt     DateTime @default(now()) @map("created_at")

  entries DailyEntry[]
  advances PayrollAdvance[]
  additions PayrollAddition[]

  @@index([employeeName, periodStart, periodEnd])
  @@map("payroll_closures")
}

model PayrollAdvance {
  id           String        @id @default(cuid())
  employeeName String        @map("employee_name")
  amount       Decimal       @db.Decimal(14, 2)
  notes        String
  status       AdvanceStatus @default(PENDENTE)
  closureId    String?       @map("closure_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  closure PayrollClosure? @relation(fields: [closureId], references: [id], onDelete: SetNull)

  @@index([employeeName, status])
  @@index([closureId])
  @@map("payroll_advances")
}

model PayrollAddition {
  id           String         @id @default(cuid())
  employeeName String         @map("employee_name")
  amount       Decimal        @db.Decimal(14, 2)
  notes        String
  status       AdditionStatus @default(PENDENTE)
  closureId    String?        @map("closure_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  closure PayrollClosure? @relation(fields: [closureId], references: [id], onDelete: SetNull)

  @@index([employeeName, status])
  @@index([closureId])
  @@map("payroll_additions")
}

model DrillingRecord {
  id            String      @id @default(cuid())
  date          DateTime
  teamName      String      @map("team_name")
  machineName   String      @map("machine_name")
  bankName      String      @map("bank_name")
  activityCode  String      @map("activity_code")
  shift         String      @default("DIA")
  motorStart    String      @map("motor_start")
  motorEnd      String      @map("motor_end")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  holes DrillingHole[]
  downtimes DrillingDowntime[]

  @@index([date, teamName])
  @@map("drilling_records")
}

model DrillingHole {
  id        String   @id @default(cuid())
  recordId  String   @map("record_id")
  holeCode  String   @map("hole_code")
  meters    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  record DrillingRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@map("drilling_holes")
}

model DrillingDowntime {
  id        String   @id @default(cuid())
  recordId  String   @map("record_id")
  reason    String
  hours     Decimal  @db.Decimal(8, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  record DrillingRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@map("drilling_downtimes")
}
model DrillingFuelEntry {
  id          String   @id @default(cuid())
  date        DateTime
  machineName String   @map("machine_name")
  quantity    Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([date, machineName])
  @@map("drilling_fuel_entries")
}
